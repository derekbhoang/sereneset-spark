# Compose deployment
APP_DOMAIN=spark.example.com
APP_VERSION=latest
APP_PORT=8080
ENVIRONMENT=production
WEB_CONCURRENCY=2
API_STOP_GRACE_PERIOD=12m
WORKER_STOP_GRACE_PERIOD=20m

# The API is only reachable through the frontend proxy in this Compose stack.
FORWARDED_ALLOW_IPS=*

# Keep browser API calls same-origin through the frontend Nginx proxy.
VITE_API_BASE_URL=/api/v1

# Use a managed PostgreSQL database and require TLS.
# Percent-encode special characters in the username and password.
DATABASE_URL=postgresql+psycopg://user:password@db.example.com:5432/sereneset_spark?sslmode=require
DATABASE_POOL_SIZE=3
DATABASE_MAX_OVERFLOW=2
DATABASE_POOL_TIMEOUT_SECONDS=30
DATABASE_POOL_RECYCLE_SECONDS=300
DATABASE_CONNECT_TIMEOUT_SECONDS=10

# Backblaze B2 S3-compatible API
B2_ENDPOINT_URL=https://s3.us-east-005.backblazeb2.com
B2_REGION_NAME=us-east-005
B2_BUCKET_NAME=replace-me
B2_APPLICATION_KEY_ID=replace-me
B2_APPLICATION_KEY=replace-me

# Genblaze / GMI Cloud
GMI_API_KEY=replace-me
GENBLAZE_IMAGE_MODEL=seedream-5.0-lite
GENBLAZE_VIDEO_MODEL=veo-3.1-fast-generate-001
GENBLAZE_TIMEOUT_SECONDS=600
GENBLAZE_VIDEO_TIMEOUT_SECONDS=900
GENBLAZE_STORAGE_PREFIX=sereneset-spark/genblaze

# Worker and artifact limits
MAX_GENERATED_VIDEO_SIZE_BYTES=524288000
GENERATION_WORKER_POLL_SECONDS=2
GENERATION_JOB_STALE_AFTER_SECONDS=1800
GENERATION_JOB_MAX_ATTEMPTS=2

# Keep this aligned with APP_DOMAIN. JSON array syntax is required.
CORS_ORIGINS=["https://spark.example.com"]
